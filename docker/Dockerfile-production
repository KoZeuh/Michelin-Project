# Build stage
FROM node:24-alpine AS builder

WORKDIR /app

# Install Bun for dependency management and Adonis build commands.
RUN npm install -g bun@1.3.14

# Copy dependency manifests.
COPY package.json bun.lock ./

# Install all dependencies, including dev dependencies for the build.
RUN bun install --frozen-lockfile

# Copy all source code.
COPY . .

# Build the AdonisJS application.
RUN bun run build

# Production stage
FROM node:24-alpine AS runner

WORKDIR /app

# Install Bun to run the production package scripts.
RUN npm install -g bun@1.3.14

# Create a non-root user.
RUN addgroup -g 1001 -S nodejs && adduser -S adonis -u 1001

# Create writable storage folders with the correct permissions.
RUN mkdir -p storage/uploads && chown -R adonis:nodejs storage

# Copy the complete build output. It contains its own package.json.
COPY --from=builder --chown=adonis:nodejs /app/build ./

# Install production dependencies inside the build folder.
RUN bun install --production

# Run as the non-root user.
USER adonis

# Expose the application port.
EXPOSE 3001

# Start the production application.
CMD ["bun", "run", "start"]
